table Products

	column ProductID
		dataType: int64
		sourceColumn: ProductID

	column ProductName
		dataType: string
		sourceColumn: ProductName

	column Category
		dataType: string
		sourceColumn: Category

	column Price
		dataType: decimal
		sourceColumn: Price

	partition Products = m
		mode: import
		source =
				let Source = #table({"ProductID", "ProductName", "Category", "Price"}, {}) in Source
